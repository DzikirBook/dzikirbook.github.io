# R2 API credentials (for npm run sync:audio / npm run dev)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: R2 public bucket URL (Vite dev proxy fallback only)
# VITE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Optional: override audio host in the built app (default = same origin)
# VITE_AUDIO_BASE_URL=https://your-cdn.example.com
